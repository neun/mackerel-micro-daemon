#!/usr/local/bin/perl
use strict;
use warnings;
use IPC::Open3;
use Time::HiRes qw(sleep);
use POSIX qw(WNOHANG);

# =================================================================
# mackerel-micro-daemon
# FreeBSD 標準機能 + Perl 標準モジュールのみ。外部CPANモジュール不要。
# =================================================================

# ----------------------------------------------------------------
# 【STEP 0】設定ファイル / 環境変数からAPIキーを読み込む
# ----------------------------------------------------------------
my $CONF_FILE = $ARGV[0] // '/usr/local/etc/mackerel-micro/mackerel-micro.conf';

sub load_conf {
    my ($path) = @_;
    return unless -f $path && -r $path;
    open(my $fh, '<', $path) or do { warn "Cannot open $path: $!\n"; return };
    while (my $line = <$fh>) {
        chomp $line;
        next if $line =~ /^\s*#/ || $line =~ /^\s*$/;
        if ($line =~ /^\s*([A-Z_][A-Z0-9_]*)\s*=\s*"?([^"]*?)"?\s*$/) {
            $ENV{$1} //= $2;
        }
    }
    close $fh;
}

load_conf($CONF_FILE);

my $API_KEY = $ENV{MACKEREL_API_KEY}
    or die "[FATAL] MACKEREL_API_KEY が設定されていません。\n"
         . "  環境変数 MACKEREL_API_KEY をセットするか、\n"
         . "  設定ファイル $CONF_FILE に MACKEREL_API_KEY=... を記載してください。\n";

# ----------------------------------------------------------------
# 定数
# ----------------------------------------------------------------
my $API_HOST = 'api.mackerelio.com';
my $ID_FILE  = $ENV{MACKEREL_ID_FILE} // '/var/lib/mackerel-agent/id';

# ----------------------------------------------------------------
# 収集除外フィルター
# ----------------------------------------------------------------
my %ignore_iface   = map { s/^\s+|\s+$//gr => 1 } split(/,/, $ENV{IGNORE_INTERFACES}  // '');
my %ignore_disk    = map { s/^\s+|\s+$//gr => 1 } split(/,/, $ENV{IGNORE_DISKS}       // '');
my %ignore_mount   = map { s/^\s+|\s+$//gr => 1 } split(/,/, $ENV{IGNORE_FILESYSTEMS} // '');
my %ignore_fstype  = map { s/^\s+|\s+$//gr => 1 } split(/,/, $ENV{IGNORE_FS_TYPES}    // '');

my @MEM_KEYS = qw(
    vm.stats.vm.v_page_size
    vm.stats.vm.v_page_count
    vm.stats.vm.v_free_count
    vm.stats.vm.v_active_count
    vm.stats.vm.v_inactive_count
    vm.stats.vm.v_wire_count
    vm.stats.vm.v_laundry_count
);

print "Mackerel Micro Daemon Initializing... (PID: $$)\n";

# ================================================================
# サブルーチン群
# ================================================================

sub reap_timed_out_child {
    my ($pid, $signal) = @_;
    return unless defined $pid;
    kill($signal, $pid);
    for (1 .. 5) {
        my $reaped = waitpid($pid, WNOHANG);
        last if $reaped != 0;
        select(undef, undef, undef, 0.1);
    }
}

# ----------------------------------------------------------------
# 【修正】ALRM発火時にスコープを抜ける前にプロセスをKILLし、
# 暗黙の close による waitpid ブロックを防止する防弾仕様。
# ----------------------------------------------------------------
sub run_cmd_safe {
    my ($timeout, @args) = @_;
    my ($output, $pid);
    eval {
        local $SIG{ALRM} = sub { 
            kill('KILL', $pid) if defined $pid; 
            die "TIMEOUT\n"; 
        };
        alarm($timeout);
        $pid = open(my $fh, '-|', @args) or die "$args[0] open failed: $!\n";
        $output = do { local $/; <$fh> };
        close $fh;
        $pid = undef;
        alarm(0);
    };
    alarm(0);
    if ($@) {
        if ($@ eq "TIMEOUT\n") {
            warn "[WARN] $args[0] timed out (${timeout}s). Skipping.\n";
        } else {
            warn "[WARN] $args[0] failed: $@";
        }
        reap_timed_out_child($pid, 'KILL') if defined $pid;
        return undef;
    }
    return $output;
}

sub json_escape {
    my ($s) = @_;
    $s =~ s{\\}{\\\\}g;
    $s =~ s{"}{\\"}g;
    $s =~ s{\n}{\\n}g;
    $s =~ s{\r}{\\r}g;
    $s =~ s{\t}{\\t}g;
    return $s;
}

sub sysctl_multi {
    my @keys = @_;
    my (%h, $pid, $fh);

    eval {
        local $SIG{ALRM} = sub { 
            kill('KILL', $pid) if defined $pid; 
            die "TIMEOUT\n"; 
        };
        alarm(2);

        $pid = open($fh, '-|', 'sysctl', @keys)
            or die "sysctl open failed: $!\n";

        my $out = do { local $/; <$fh> };
        close $fh;
        $pid = undef;
        alarm(0);

        for my $line (split(/\n/, $out)) {
            $h{$1} = $2 if $line =~ /^([^:]+):\s*(.*)$/;
        }
    };
    alarm(0);

    if ($@) {
        if ($@ eq "TIMEOUT\n") {
            warn "[WARN] sysctl timed out (2s). Skipping this collection.\n";
            reap_timed_out_child($pid, 'KILL');
        } else {
            warn "[WARN] sysctl failed: $@";
        }
        %h = ();
    }
    return %h;
}

# ----------------------------------------------------------------
# 【修正】SIGPIPE を無視し、openssl突然死によるデーモンクラッシュを防止
# ----------------------------------------------------------------
sub send_https_request {
    my ($method, $path, $json) = @_;

    my $body = $json // '';
    my $request = "${method} ${path} HTTP/1.1\r\n"
                . "Host: ${API_HOST}\r\n"
                . "X-Api-Key: ${API_KEY}\r\n"
                . "Content-Type: application/json\r\n"
                . "Content-Length: " . length($body) . "\r\n"
                . "Connection: close\r\n\r\n"
                . $body;

    my ($status, $response) = (0, '');
    my $child_pid;

    eval {
        local $SIG{ALRM} = sub { die "TIMEOUT\n" };
        local $SIG{PIPE} = 'IGNORE'; # SIGPIPEによるプロセス終了を防止
        alarm(10);

        my ($chld_in, $chld_out);
        open(my $devnull, '>', '/dev/null') or die "Cannot open /dev/null: $!\n";
        $child_pid = open3($chld_in, $chld_out, $devnull,
            'openssl', 's_client', '-connect', "${API_HOST}:443", '-quiet');
        print $chld_in $request;
        close $chld_in;

        $response = do { local $/; <$chld_out> };
        close $chld_out;
        waitpid($child_pid, 0);
        $child_pid = undef;
        alarm(0);

        $status = $1 + 0 if $response =~ m{HTTP/1\.1 (\d{3}) };
    };
    alarm(0);

    reap_timed_out_child($child_pid, 'TERM') if defined $child_pid;

    if ($@) {
        warn "send_https_request: $@";
        return (0, '');
    }
    return ($status, $response);
}

sub get_cp_time {
    my $raw = run_cmd_safe(2, 'sysctl', '-n', 'kern.cp_time') // '';
    return split(/\s+/, $raw);
}

sub fs_meta_to_json {
    my (%fs) = @_;
    my @entries;
    for my $dev (sort keys %fs) {
        my $info = $fs{$dev};
        push @entries, sprintf(
            '"%s":{"kb_size":%d,"kb_used":%d,"kb_available":%d,"percent_used":"%d%%","mount":"%s"}',
            json_escape($dev),
            $info->{kb_size}, $info->{kb_used}, $info->{kb_available},
            $info->{percent_used}, json_escape($info->{mount})
        );
    }
    return "{" . join(",", @entries) . "}";
}

# ================================================================
# グローバルキャッシュ (fork削減のためサブルーチン後・PHASE 1前に取得)
# ================================================================
my $core_count = ((run_cmd_safe(2, 'sysctl', '-n', 'hw.ncpu') // '1') + 0) || 1;

# ----------------------------------------------------------------
# ホストスペック JSON を組み立てる
# 【修正】hw.ncpu の重複取得を廃止し、グローバルの $core_count を利用
# ----------------------------------------------------------------
sub build_spec_json {
    my (%fs) = @_;

    my $hostname = run_cmd_safe(2, 'hostname')  // ''; chomp $hostname;
    my $arch     = run_cmd_safe(2, 'uname', '-p') // ''; chomp $arch;
    my $os_rel   = run_cmd_safe(2, 'uname', '-r') // ''; chomp $os_rel;

    my %sc        = sysctl_multi(qw(hw.model hw.physmem));
    my $cpu_model = $sc{'hw.model'} // 'unknown'; $cpu_model =~ s/^\s+|\s+$//g;
    my $phys_mem  = ($sc{'hw.physmem'} // 0) + 0;
    my $mem_kb    = int($phys_mem / 1024) . "kB";

    my $cpu_model_esc = json_escape($cpu_model);
    my $hostname_esc  = json_escape($hostname);
    my $arch_esc      = json_escape($arch);
    my $os_rel_esc    = json_escape($os_rel);

    my @cpu_array = map { sprintf('{"model_name":"%s","cores":"1"}', $cpu_model_esc) } (1 .. $core_count);
    my $cpu_json  = "[" . join(",", @cpu_array) . "]";
    my $fs_json   = fs_meta_to_json(%fs);

    return sprintf(
        '{"name":"%s","meta":{'
            . '"agent-name":"mackerel-micro-daemon/v1.6.4",'
            . '"agent-revision":"ops",'
            . '"agent-version":"1.6.4",'
            . '"cpu":%s,'
            . '"filesystem":%s,'
            . '"kernel":{"machine":"%s","name":"FreeBSD","os":"FreeBSD","release":"%s"},'
            . '"memory":{"total":"%s"}'
        . '},'
        . '"interfaces":[],"roleFullnames":[],"checks":[]}',
        $hostname_esc, $cpu_json, $fs_json, $arch_esc, $os_rel_esc, $mem_kb
    );
}

sub metric_json {
    my ($host_id, $name, $time, $value) = @_;
    $value = 0 unless defined $value && $value =~ /^-?[\d\.]+$/;
    return sprintf('{"hostId":"%s","name":"%s","time":%d,"value":%s}',
        $host_id, $name, $time, $value);
}

# ================================================================
# 【PHASE 1】ホストID の確保
# ================================================================
my $host_id = '';

if (-f $ID_FILE && -s $ID_FILE) {
    open(my $fh, '<', $ID_FILE) or die "Cannot open $ID_FILE: $!\n";
    $host_id = <$fh>; chomp $host_id; close $fh;
    $host_id =~ s/\s+//g;
}

if ($host_id) {
    print "Loaded Host ID: $host_id\n";
    print "Checking host status on Mackerel...\n";
    my ($get_code, $get_res) = (0, '');
    for my $attempt (1 .. 3) {
        ($get_code, $get_res) = send_https_request('GET', "/api/v0/hosts/$host_id", '');
        last if $get_code != 0;
        warn "[WARN] Cannot reach Mackerel API (attempt $attempt/3). Retrying in 5s...\n";
        sleep(5);
    }

    if    ($get_code == 0)                         { die "[FATAL] Cannot reach Mackerel API after 3 attempts.\n" }
    elsif ($get_code == 404)                       { die "[FATAL] Host $host_id not found (404). $ID_FILE may be stale.\n"
                                                       . "  rm $ID_FILE && service mackerel_micro start\n" }
    elsif ($get_code == 429 || $get_code >= 500)   { warn "[WARN] Mackerel returned ${get_code} on startup check. Proceeding.\n" }
    elsif ($get_code != 200)                       { die "[FATAL] Unexpected API response (${get_code}). Aborting.\n" }
    elsif ($get_res =~ /"isRetired"\s*:\s*true/) {
        die "[FATAL] Host $host_id is retired on Mackerel.\n"
          . "  rm $ID_FILE && service mackerel_micro start\n";
    }
    print "Host is active.\n" if $get_code == 200;
} else {
    print "Host ID not found. Registering as a new host...\n";

    my %fs_for_register;
    for my $line (split(/\n/, run_cmd_safe(10, 'df', '-k') // '')) {
        next if $line =~ /^(?:Filesystem|devfs|procfs|linprocfs|fdescfs|tmpfs|nullfs)/;
        if ($line =~ /^(\S+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)%\s+(\S+)/) {
            $fs_for_register{$1} = {
                kb_size      => $2 + 0,
                kb_used      => $3 + 0,
                kb_available => $4 + 0,
                percent_used => $5 + 0,
                mount        => $6,
            };
        }
    }

    my $spec_json = build_spec_json(%fs_for_register);
    my ($post_code, $post_res) = send_https_request('POST', '/api/v0/hosts', $spec_json);

    die "[FATAL] Host registration failed (${post_code}). API response:\n$post_res\n"
        unless $post_code == 200 && $post_res =~ /"id"\s*:\s*"([^"]+)"/;
    $host_id = $1;

    (my $id_dir = $ID_FILE) =~ s{/[^/]+$}{};
    mkdir $id_dir or die "Cannot create directory $id_dir: $!\n"
        if $id_dir && ! -d $id_dir;

    open(my $fh, '>', $ID_FILE) or die "Cannot write $ID_FILE: $!\n";
    print $fh $host_id; close $fh;
    print "New host registered! Host ID: $host_id (saved to $ID_FILE)\n";
}

# ================================================================
# 【PHASE 2】定期メトリック送信ループ
# ================================================================
print "Starting metric loop. Interval: 60s\n";

my %prev_net;
my @prev_cp_time = get_cp_time();
my $loop_count   = 0;

while (1) {
    my $loop_start = time();
    my $now = $loop_start;
    my @metrics;
    $loop_count++;

    # --- [1] CPU 利用率 ---
    my @cp_time = get_cp_time();
    if (@cp_time == 5 && @prev_cp_time == 5) {
        my @delta          = map { $cp_time[$_] - $prev_cp_time[$_] } (0 .. 4);
        my ($d_user, $d_nice, $d_sys, $d_intr, $d_idle) = @delta;
        my $d_system_total = $d_sys + $d_intr;
        my $total          = $d_user + $d_nice + $d_system_total + $d_idle;

        if ($total > 0) {
            my $scale = 100 * $core_count / $total;
            push @metrics,
                metric_json($host_id, "cpu.user.percentage",   $now, sprintf("%.2f", $d_user         * $scale)),
                metric_json($host_id, "cpu.nice.percentage",   $now, sprintf("%.2f", $d_nice         * $scale)),
                metric_json($host_id, "cpu.system.percentage", $now, sprintf("%.2f", $d_system_total * $scale)),
                metric_json($host_id, "cpu.idle.percentage",   $now, sprintf("%.2f", $d_idle         * $scale));
        }
    }
    @prev_cp_time = @cp_time;

    # --- [2] メモリ (一括 sysctl) ---
    my %sc         = sysctl_multi(@MEM_KEYS);
    my $page_size  = ($sc{'vm.stats.vm.v_page_size'}      // 0) + 0;
    my $page_count = ($sc{'vm.stats.vm.v_page_count'}     // 0) + 0;
    my $free_cnt   = ($sc{'vm.stats.vm.v_free_count'}     // 0) + 0;
    my $active_cnt = ($sc{'vm.stats.vm.v_active_count'}   // 0) + 0;
    my $inact_cnt  = ($sc{'vm.stats.vm.v_inactive_count'} // 0) + 0;
    my $wire_cnt   = ($sc{'vm.stats.vm.v_wire_count'}     // 0) + 0;
    my $laund_cnt  = ($sc{'vm.stats.vm.v_laundry_count'}  // 0) + 0;

    push @metrics,
        metric_json($host_id, "memory.total",    $now, $page_count * $page_size),
        metric_json($host_id, "memory.free",     $now, ($free_cnt + $inact_cnt + $laund_cnt) * $page_size),
        metric_json($host_id, "memory.used",     $now, ($wire_cnt + $active_cnt)             * $page_size),
        metric_json($host_id, "memory.active",   $now, $active_cnt * $page_size),
        metric_json($host_id, "memory.inactive", $now, $inact_cnt  * $page_size);

    # --- [3] ロードアベレージ ---
    my $loadavg = run_cmd_safe(2, 'sysctl', '-n', 'vm.loadavg') // '';
    if ($loadavg =~ /([\d\.]+)\s+([\d\.]+)\s+([\d\.]+)/) {
        push @metrics,
            metric_json($host_id, "loadavg1",  $now, $1),
            metric_json($host_id, "loadavg5",  $now, $2),
            metric_json($host_id, "loadavg15", $now, $3);
    }

    # --- [4] ネットワーク ---
    # 【修正】初回実行時（prevが存在しない時）のゼロ送信を防止
    my %current_net;
    for my $line (split(/\n/, run_cmd_safe(5, 'netstat', '-bni') // '')) {
        next if $line =~ /^(?:Name|lo|plip)/ || $line =~ /Link/;
        my @cols = split(/\s+/, $line);
        my ($iface, $rx, $tx) = ($cols[0], $cols[7], $cols[10]);
        next unless defined($rx) && defined($tx) && $iface !~ /\*/;
        next if $ignore_iface{$iface};

        $current_net{$iface} = { rx => $rx, tx => $tx };

        if (exists $prev_net{$iface}) {
            my $d_rx = $rx >= $prev_net{$iface}{rx} ? $rx - $prev_net{$iface}{rx} : 0;
            my $d_tx = $tx >= $prev_net{$iface}{tx} ? $tx - $prev_net{$iface}{tx} : 0;
            push @metrics,
                metric_json($host_id, "interface.${iface}.rxBytes.delta", $now, $d_rx),
                metric_json($host_id, "interface.${iface}.txBytes.delta", $now, $d_tx);
        }
    }

    # --- [5] ディスク使用量 ---
    my %mount_fstype;
    if (%ignore_fstype) {
        for my $mline (split(/\n/, run_cmd_safe(5, 'mount') // '')) {
            if ($mline =~ /^\S+\s+on\s+(.+?)\s+\((\w+)/) {
                $mount_fstype{$1} = $2;
            }
        }
    }

    my %fs_meta;
    for my $line (split(/\n/, run_cmd_safe(10, 'df', '-k') // '')) {
        next if $line =~ /^(?:Filesystem|devfs|procfs|linprocfs|fdescfs|tmpfs|nullfs)/;
        next unless $line =~ /^(\S+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)%\s+(\S+)/;

        my ($dev_raw, $total_kb, $used_kb, $avail_kb, $pct, $mount) = ($1,$2,$3,$4,$5,$6);
        next if $ignore_mount{$mount};
        next if %ignore_fstype && $ignore_fstype{ $mount_fstype{$mount} // '' };
        (my $dev_clean = $dev_raw) =~ s{^/dev/}{};
        $dev_clean =~ s{[^\w\-\.]+}{-}g;
        $dev_clean =~ s{^-|-$}{}g;

        push @metrics,
            metric_json($host_id, "filesystem.${dev_clean}.size", $now, $total_kb * 1024),
            metric_json($host_id, "filesystem.${dev_clean}.used", $now, $used_kb  * 1024);

        $fs_meta{$dev_raw} = {
            kb_size      => $total_kb + 0,
            kb_used      => $used_kb  + 0,
            kb_available => $avail_kb + 0,
            percent_used => $pct      + 0,
            mount        => $mount,
        };
    }

    # --- [6] スワップ情報 (swapinfo) ---
    {
        my ($swap_pid, $swap_fh);
        my ($swap_total, $swap_free) = (0, 0);
        eval {
            local $SIG{ALRM} = sub { 
                kill('KILL', $swap_pid) if defined $swap_pid; 
                die "TIMEOUT\n"; 
            };
            alarm(2);

            $swap_pid = open($swap_fh, '-|', 'swapinfo', '-k')
                or die "swapinfo open failed: $!\n";

            while (my $line = <$swap_fh>) {
                if ($line =~ /\s+(\d+)\s+\d+\s+(\d+)\s+\d+%/) {
                    $swap_total += $1 * 1024;
                    $swap_free  += $2 * 1024;
                }
            }
            close $swap_fh;
            $swap_pid = undef;
            alarm(0);

            push @metrics,
                metric_json($host_id, "memory.swap_total", $now, $swap_total),
                metric_json($host_id, "memory.swap_free",  $now, $swap_free);
        };
        alarm(0);
        if ($@) {
            if ($@ eq "TIMEOUT\n") {
                warn "[WARN] swapinfo timed out (2s). Skipping swap metrics.\n";
            } else {
                warn "[WARN] swapinfo failed: $@";
            }
            reap_timed_out_child($swap_pid, 'KILL');
        }
    }

    # --- [7] ディスク I/O ---
    {
        my ($iostat_pid, $iostat_fh);
        eval {
            local $SIG{ALRM} = sub { 
                kill('KILL', $iostat_pid) if defined $iostat_pid; 
                die "TIMEOUT\n"; 
            };
            alarm(3);

            $iostat_pid = open($iostat_fh, '-|', 'iostat', '-x', '-c', '2', '-w', '1')
                or die "iostat open failed: $!\n";

            my $capture = 0;
            while (my $line = <$iostat_fh>) {
                if ($line =~ /extended device statistics/i) {
                    $capture = 1; <$iostat_fh>; next;
                }
                next unless $capture;
                my @cols = split(/\s+/, $line);
                next if @cols < 4;
                my ($dev, $r_s, $w_s) = $cols[0] eq ''
                    ? @cols[1,2,3]
                    : @cols[0,1,2];
                next unless $dev && $r_s =~ /^[\d\.]+$/;
                next if $ignore_disk{$dev};
                push @metrics,
                    metric_json($host_id, "disk.$dev.reads.delta",  $now, $r_s),
                    metric_json($host_id, "disk.$dev.writes.delta", $now, $w_s);
            }
            close $iostat_fh;
            $iostat_pid = undef;
            alarm(0);
        };
        alarm(0);

        if ($@) {
            if ($@ eq "TIMEOUT\n") {
                warn "[WARN] iostat timed out (3s). Skipping disk I/O metrics.\n";
            } else {
                warn "[WARN] iostat failed: $@";
            }
            reap_timed_out_child($iostat_pid, 'KILL');
        }
    }

    # --- [8] メトリック POST ---
    my $payload = "[" . join(',', @metrics) . "]";
    my ($post_code, $res) = send_https_request('POST', '/api/v0/tsdb', $payload);

    if    ($post_code == 200)                              { }
    elsif ($post_code == 0 || $post_code == 429
                           || $post_code >= 500)           { warn "Metric post failed (${post_code}, loop=$loop_count). Will retry.\n" }
    else                                                   { die "[FATAL] Metric post rejected (${post_code}). Terminating daemon.\n" }

    # --- [9] ネットワークカウンタのコミット ---
    %prev_net = %current_net if $post_code == 200;

    # --- [10] 初回のみホストスペック PUT ---
    if ($loop_count == 1) {
        my $spec_json  = build_spec_json(%fs_meta);
        my ($put_code) = send_https_request('PUT', "/api/v0/hosts/$host_id", $spec_json);
        if    ($put_code == 200)                               { print "Host spec updated successfully.\n" }
        elsif ($put_code == 0 || $put_code == 429
                              || $put_code >= 500)             { warn "Host spec PUT failed (${put_code}). Will not retry.\n" }
        else                                                   { warn "Host spec PUT rejected (${put_code}). Continuing.\n" }
    }

    # --- [11] elapsed time を差し引いて正確に60秒間隔を維持 ---
    my $elapsed  = time() - $loop_start;
    my $sleep_sec = 60 - $elapsed;
    if ($sleep_sec > 0) {
        sleep($sleep_sec);
    } else {
        warn "[WARN] loop took ${elapsed}s (>60s), skipping sleep.\n";
    }
}
